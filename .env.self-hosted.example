# =============================================================================
# SessionForge — Self-Hosted / BYO Infrastructure Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For Vercel or managed deployments, see .env.example instead.
#
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# =============================================================================
# REQUIRED — The app will not start without these
# =============================================================================

# Your PostgreSQL connection string (standard postgres:// or postgresql://)
# Example: postgresql://sessionforge:password@localhost:5432/sessionforge
DATABASE_URL=postgresql://sessionforge:changeme@localhost:5432/sessionforge

# Random secret used to sign auth tokens and sessions
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# The public-facing URL of your deployment (no trailing slash)
# Used for OAuth redirects, email links, and CORS
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Same as NEXT_PUBLIC_APP_URL — used internally by better-auth for URL validation
BETTER_AUTH_URL=https://your-domain.com

# =============================================================================
# DATABASE — Driver selection
# =============================================================================

# Force the Postgres.js driver instead of Neon's serverless driver.
# Required when connecting to a standard PostgreSQL instance (not Neon).
# Options: "postgres" (standard) | "neon" (Neon serverless)
DATABASE_DRIVER=postgres

# =============================================================================
# CACHE — Redis (choose one provider)
# =============================================================================

# Standard Redis connection URL (ioredis-compatible).
# Use this when running your own Redis instance (e.g. via Docker Compose).
# Example: redis://localhost:6379  or  redis://:password@redis:6379
REDIS_URL=redis://redis:6379

# --- Upstash Redis alternative (comment out REDIS_URL above if using Upstash) ---
# Managed serverless Redis from Upstash. Required for Vercel/edge deployments.
# Sign up at https://upstash.com and create a Redis database.
# UPSTASH_REDIS_URL=https://your-database.upstash.io
# UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# =============================================================================
# QUEUE — Background jobs and automation
# =============================================================================

# Secret used to authenticate cron/webhook requests to /api/cron/automation.
# Generate with: openssl rand -base64 32
# Set this same value as the Authorization Bearer token in your cron job config.
CRON_SECRET=change-me-generate-with-openssl-rand-base64-32

# --- Upstash QStash alternative (comment out CRON_SECRET if using QStash) ---
# Managed message queue from Upstash. Required for Vercel/edge deployments.
# Sign up at https://upstash.com and create a QStash instance.
# UPSTASH_QSTASH_TOKEN=your-qstash-token
# UPSTASH_QSTASH_CURRENT_SIGNING_KEY=sig_your-current-signing-key
# UPSTASH_QSTASH_NEXT_SIGNING_KEY=sig_your-next-signing-key

# =============================================================================
# AUTH — OAuth providers (optional)
# =============================================================================

# GitHub OAuth App credentials for GitHub login.
# Create an OAuth App at: https://github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# BILLING — Stripe (optional)
# =============================================================================

# Stripe secret key — use sk_test_... for staging, sk_live_... for production.
# Find in: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe webhook signing secret — validates incoming webhook events.
# Create a webhook endpoint at: https://dashboard.stripe.com/webhooks
# Point it to: https://your-domain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# =============================================================================
# AI — Claude Agent SDK (optional)
# =============================================================================

# Set to "true" to disable all AI agent features (session scanning, generation).
# When disabled, AI routes return graceful error messages and the UI shows
# an error state — all other features (editing, publishing) continue to work.
# Default: false (AI enabled if Claude CLI is installed and authenticated)
DISABLE_AI_AGENTS=false

# =============================================================================
# OBSERVABILITY — Deployment validation (optional)
# =============================================================================

# Bearer token required to call GET /api/deployment/validate.
# When set, unauthenticated requests to the validation endpoint return 401.
# Leave unset to allow unauthenticated health/readiness checks.
# Generate with: openssl rand -base64 32
DEPLOYMENT_VALIDATE_TOKEN=change-me-generate-with-openssl-rand-base64-32
