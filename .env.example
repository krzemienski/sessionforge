# Database
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/sessionforge

# Auth
BETTER_AUTH_SECRET=random-secret-string
BETTER_AUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

# AI — No API key needed. Uses @anthropic-ai/claude-agent-sdk (CLI auth).
# DISABLE_AI_AGENTS=true  # Set to disable AI features (e.g., in Docker)

# Cache & Queue
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx
UPSTASH_QSTASH_TOKEN=xxx
UPSTASH_QSTASH_CURRENT_SIGNING_KEY=xxx
UPSTASH_QSTASH_NEXT_SIGNING_KEY=xxx

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
