# Database (Neon Serverless Postgres)
# Production (pooled — use for app connections):
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-PROJECT-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooled — use for migrations only):
# DATABASE_URL_DIRECT=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-PROJECT.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth
BETTER_AUTH_SECRET=random-secret-string
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx
GITHUB_WEBHOOK_SECRET=xxx

# AI — uses @anthropic-ai/claude-agent-sdk with CLI-inherited auth
# No API key needed. The SDK spawns the claude CLI subprocess.
# DISABLE_AI_AGENTS=true  # Set to disable AI features in local dev

# Cache & Queue
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx
UPSTASH_QSTASH_TOKEN=xxx
UPSTASH_QSTASH_CURRENT_SIGNING_KEY=xxx
UPSTASH_QSTASH_NEXT_SIGNING_KEY=xxx

# Billing (Stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEPLOYMENT_TYPE=local
BETTER_AUTH_URL=http://localhost:3000
